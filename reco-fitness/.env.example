# ============================================================
# Reco-Fitness -- Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# ============================================================

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reco_fitness
DB_USER=postgres
DB_PASSWORD=changeme

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=reco_fitness

# --- Authentification MSPR-AUTH ---
# Secret partage avec le service d'authentification
BETTER_AUTH_SECRET=changeme_secret_32_chars_minimum
# URL du service MSPR-AUTH (ex: http://mspr-auth:8001 en Docker)
AUTH_API_URL=http://localhost:8001

# --- Scoring ML ---
# Entraine scoring_model.pkl au demarrage s'il est absent (l'image Docker ne
# l'embarque pas, il est gitignore). Requis pour le scoring hybride premium.
SCORING_AUTOTRAIN=1
